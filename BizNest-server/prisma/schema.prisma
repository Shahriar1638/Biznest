// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// ENUMS
// ==========================================

enum Role {
  admin
  customer
  seller
}

enum SellerOfferType {
  percent
  fixed
  bogo
}

enum SellerOfferTargetType {
  product
  variant
}

enum AdminOfferType {
  percent
  fixed
}

enum AdminOfferTargetType {
  product
  variant
  category
}

// ==========================================
// CORE USERS & PROFILES
// ==========================================

model User {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email         String    @unique @db.VarChar(255)
  password_hash String
  name          String    @db.VarChar(100)
  phone         String?   @db.VarChar(20)
  role          Role      @default(customer)
  gender        String?   @db.VarChar(10)
  photo_url     String?
  address       String?
  is_banned     Boolean   @default(false)
  is_archived   Boolean   @default(false)
  created_at    DateTime  @default(now()) @db.Timestamptz
  updated_at    DateTime  @default(now()) @db.Timestamptz

  seller        Seller?
  customer      Customer?
  admin         Admin?

  tickets_sent     SupportTicket[]   @relation("TicketSender")
  assigned_tickets SupportTicket[]   @relation("TicketAssignee")
  ticket_messages  TicketMessage[]
  resolved_meta    TicketAdminMeta[] @relation("ResolvedBy")
  banners          Banner[]
  status_updates   Product[]         @relation("StatusUpdater")
  addresses        Address[]

  @@map("users")
}

model Seller {
  id                String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id           String  @unique @db.Uuid
  store_name        String  @db.VarChar(255)
  store_description String?

  user            User              @relation(fields: [user_id], references: [id], onDelete: Cascade)
  financials      SellerFinancials?
  statements      SellerStatement[]
  offers          SellerOffer[]
  products        Product[]
  banner_payments BannerPayment[]
  order_items     OrderItem[]

  @@map("sellers")
}

model SellerFinancials {
  id                           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  seller_id                    String   @unique @db.Uuid
  verification_status          String   @default("pending") @db.VarChar(20)
  business_registration_number String?  @db.VarChar(100)
  bank_account_details         Json?
  updated_at                   DateTime @default(now()) @db.Timestamptz

  seller Seller @relation(fields: [seller_id], references: [id], onDelete: Cascade)

  @@map("seller_financials")
}

model Customer {
  id                          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id                     String  @unique @db.Uuid
  stripe_customer_id          String? @db.VarChar(255)
  default_shipping_address_id String? @db.Uuid
  points                      Int     @default(0)

  user             User           @relation(fields: [user_id], references: [id], onDelete: Cascade)
  default_address  Address?       @relation("DefaultAddress", fields: [default_shipping_address_id], references: [id], onDelete: SetNull)
  wishlist         WishlistItem[]
  reviews          Review[]
  orders           Order[]

  @@map("customers")
}

model Address {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id      String   @db.Uuid
  address_line String
  house_no     String?  @db.VarChar(50)
  city         String   @db.VarChar(100)
  district     String?  @db.VarChar(100)
  region       String?  @db.VarChar(100)
  postal_code  String?  @db.VarChar(20)
  country      String   @db.VarChar(100)
  created_at   DateTime @default(now()) @db.Timestamptz
  updated_at   DateTime @default(now()) @db.Timestamptz

  user               User       @relation(fields: [user_id], references: [id], onDelete: Cascade)
  default_customers  Customer[] @relation("DefaultAddress")

  @@map("address")
}

model Admin {
  id      String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id String  @unique @db.Uuid
  salary  Decimal @default(0.00) @db.Decimal(15, 2)

  user    User    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("admins")
}

// ==========================================
// PRODUCTS & INVENTORY
// ==========================================

model Category {
  id   Int    @id @default(autoincrement())
  name String @unique @db.VarChar(50)

  products            Product[]
  admin_offer_targets AdminOfferTarget[]

  @@map("categories")
}

model Product {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  seller_id         String    @db.Uuid
  category_id       Int
  product_name      String    @db.VarChar(255)
  product_imgurl    String?
  description       String?
  status            String    @default("pending") @db.VarChar(20)
  metadata          Json?
  status_updated_by String?   @db.Uuid
  status_updated_at DateTime? @db.Timestamptz
  created_at        DateTime  @default(now()) @db.Timestamptz
  updated_at        DateTime  @default(now()) @db.Timestamptz

  seller               Seller              @relation(fields: [seller_id], references: [id], onDelete: Restrict)
  category             Category            @relation(fields: [category_id], references: [id], onDelete: Restrict)
  updater              User?               @relation("StatusUpdater", fields: [status_updated_by], references: [id], onDelete: SetNull)
  variants             ProductVariant[]
  reviews              Review[]
  support_tickets      SupportTicket[]
  seller_offer_targets SellerOfferTarget[]
  admin_offer_targets  AdminOfferTarget[]

  @@index([status])
  @@map("products")
}

model ProductVariant {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  product_id String   @db.Uuid
  unit_type  String?  @db.VarChar(50)
  unit_name  String?  @db.VarChar(50)
  price      Decimal  @db.Decimal(12, 2)
  created_at DateTime @default(now()) @db.Timestamptz
  updated_at DateTime @default(now()) @db.Timestamptz

  product              Product              @relation(fields: [product_id], references: [id], onDelete: Cascade)
  inventories          Inventory[]
  order_items          OrderItem[]
  wishlisted_by        WishlistItem[]
  seller_offer_targets SellerOfferTarget[]
  admin_offer_targets  AdminOfferTarget[]

  @@map("product_variants")
}

model Region {
  id   Int    @id @default(autoincrement())
  name String @unique @db.VarChar(100)

  inventories   Inventory[]
  orders        Order[]
  delivery_logs DeliveryLog[]

  @@map("regions")
}

model Inventory {
  id          String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  variant_id  String @db.Uuid
  region_id   Int
  stock_count Int    @default(0)

  variant     ProductVariant @relation(fields: [variant_id], references: [id], onDelete: Cascade)
  region      Region         @relation(fields: [region_id], references: [id], onDelete: Cascade)

  @@unique([variant_id, region_id])
  @@map("inventory")
}

model Review {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  product_id  String   @db.Uuid
  customer_id String?  @db.Uuid
  rate        Int?
  comment     String?
  created_at  DateTime @default(now()) @db.Timestamptz

  product     Product   @relation(fields: [product_id], references: [id], onDelete: Cascade)
  customer    Customer? @relation(fields: [customer_id], references: [id], onDelete: SetNull)

  @@unique([product_id, customer_id])
  @@map("reviews")
}

model WishlistItem {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customer_id String   @db.Uuid
  variant_id  String   @db.Uuid
  added_at    DateTime @default(now()) @db.Timestamptz

  customer    Customer       @relation(fields: [customer_id], references: [id], onDelete: Cascade)
  variant     ProductVariant @relation(fields: [variant_id], references: [id], onDelete: Cascade)

  @@unique([customer_id, variant_id])
  @@map("wishlist")
}

// ==========================================
// OFFERS & DISCOUNTS
// ==========================================

model SellerOffer {
  id          String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  seller_id   String          @db.Uuid
  title       String          @db.VarChar(150)
  type        SellerOfferType
  percent_off Decimal?        @db.Decimal(5, 2)
  fixed_off   Decimal?        @db.Decimal(12, 2)
  buy_qty     Int?
  get_qty     Int?
  priority    Int             @default(0)
  starts_at   DateTime        @db.Timestamptz
  ends_at     DateTime        @db.Timestamptz
  is_active   Boolean         @default(true)
  created_at  DateTime        @default(now()) @db.Timestamptz
  updated_at  DateTime        @default(now()) @db.Timestamptz

  seller      Seller              @relation(fields: [seller_id], references: [id], onDelete: Cascade)
  targets     SellerOfferTarget[]

  @@index([starts_at, ends_at])
  @@map("seller_offers")
}

model SellerOfferTarget {
  id          String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  offer_id    String                @db.Uuid
  target_type SellerOfferTargetType
  product_id  String?               @db.Uuid
  variant_id  String?               @db.Uuid

  offer       SellerOffer      @relation(fields: [offer_id], references: [id], onDelete: Cascade)
  product     Product?         @relation(fields: [product_id], references: [id], onDelete: Cascade)
  variant     ProductVariant?  @relation(fields: [variant_id], references: [id], onDelete: Cascade)

  @@unique([offer_id, product_id])
  @@unique([offer_id, variant_id])
  @@map("seller_offer_targets")
}

model AdminOffer {
  id                        String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title                     String         @db.VarChar(150)
  type                      AdminOfferType
  percent_off               Decimal?       @db.Decimal(5, 2)
  fixed_off                 Decimal?       @db.Decimal(12, 2)
  is_global                 Boolean        @default(false)
  stacks_with_seller_offers Boolean        @default(true)
  starts_at                 DateTime       @db.Timestamptz
  ends_at                   DateTime       @db.Timestamptz
  is_active                 Boolean        @default(true)
  created_at                DateTime       @default(now()) @db.Timestamptz
  updated_at                DateTime       @default(now()) @db.Timestamptz

  targets                   AdminOfferTarget[]

  @@index([starts_at, ends_at])
  @@map("admin_offers")
}

model AdminOfferTarget {
  id          String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  offer_id    String                @db.Uuid
  target_type AdminOfferTargetType?
  product_id  String?               @db.Uuid
  variant_id  String?               @db.Uuid
  category_id Int?

  offer       AdminOffer       @relation(fields: [offer_id], references: [id], onDelete: Cascade)
  product     Product?         @relation(fields: [product_id], references: [id], onDelete: Cascade)
  variant     ProductVariant?  @relation(fields: [variant_id], references: [id], onDelete: Cascade)
  category    Category?        @relation(fields: [category_id], references: [id], onDelete: Cascade)

  @@unique([offer_id, product_id])
  @@unique([offer_id, variant_id])
  @@unique([offer_id, category_id])
  @@map("admin_offer_targets")
}

// ==========================================
// ORDERS, PAYMENTS, & LOGISTICS
// ==========================================

model Order {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customer_id     String   @db.Uuid
  region_id       Int
  total_amount    Decimal  @db.Decimal(15, 2)
  delivery_status String?  @default("processing") @db.VarChar(50)
  order_status    String?  @default("cart") @db.VarChar(50)
  created_at      DateTime @default(now()) @db.Timestamptz
  updated_at      DateTime @default(now()) @db.Timestamptz

  customer        Customer        @relation(fields: [customer_id], references: [id], onDelete: Restrict)
  region          Region          @relation(fields: [region_id], references: [id], onDelete: Restrict)
  items           OrderItem[]
  payment         Payment?
  support_tickets SupportTicket[]
  delivery_logs   DeliveryLog[]

  @@index([customer_id, order_status])
  @@map("orders")
}

model OrderItem {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  order_id          String   @db.Uuid
  variant_id        String   @db.Uuid
  seller_id         String   @db.Uuid
  quantity               Int
  price_at_purchase      Decimal  @db.Decimal(12, 2)
  product_name_snapshot  String   @db.VarChar(255)
  variant_label_snapshot String?  @db.VarChar(100)
  discount_amount        Decimal  @default(0) @db.Decimal(12, 2)
  created_at        DateTime @default(now()) @db.Timestamptz
  updated_at        DateTime @default(now()) @db.Timestamptz

  order             Order          @relation(fields: [order_id], references: [id], onDelete: Cascade)
  variant           ProductVariant @relation(fields: [variant_id], references: [id], onDelete: Restrict)
  seller            Seller         @relation(fields: [seller_id], references: [id], onDelete: Restrict)

  @@unique([order_id, variant_id])
  @@map("order_items")
}

model Payment {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  order_id          String    @unique @db.Uuid
  stripe_intent_id  String?   @db.VarChar(255)
  transaction_id    String?   @db.VarChar(255)
  payment_method_id String?   @db.VarChar(255)
  amount            Decimal   @db.Decimal(15, 2)
  payment_status    String?   @db.VarChar(50)
  created_at        DateTime  @default(now()) @db.Timestamptz
  completed_at      DateTime? @db.Timestamptz

  order             Order     @relation(fields: [order_id], references: [id], onDelete: Restrict)

  @@map("payments")
}

model DeliveryLog {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  order_id          String   @db.Uuid
  current_region_id Int?
  delivery_status   String?  @db.VarChar(50)
  updated_at        DateTime @default(now()) @db.Timestamptz

  order             Order    @relation(fields: [order_id], references: [id], onDelete: Cascade)
  current_region    Region?  @relation(fields: [current_region_id], references: [id], onDelete: SetNull)

  @@map("delivery_logs")
}

// ==========================================
// FINANCIAL REPORTING
// ==========================================

model SellerStatement {
  id                      String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  seller_id               String   @db.Uuid
  period_start            DateTime @db.Date
  gross_sales             Decimal  @default(0) @db.Decimal(12, 2)
  seller_funded_discounts Decimal  @default(0) @db.Decimal(12, 2)
  admin_funded_discounts  Decimal  @default(0) @db.Decimal(12, 2)
  inventory_fee           Decimal  @default(0) @db.Decimal(12, 2)
  net_payout              Decimal  @db.Decimal(12, 2) // GENERATED ALWAYS AS
  generated_at            DateTime @default(now()) @db.Timestamptz

  seller                  Seller   @relation(fields: [seller_id], references: [id], onDelete: Restrict)

  @@unique([seller_id, period_start])
  @@map("seller_statements")
}

model PlatformRevenue {
  id                          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  period_start                DateTime @unique @db.Date
  revenue_from_inventory_fee  Decimal  @default(0) @db.Decimal(12, 2)
  revenue_from_other_fees     Decimal  @default(0) @db.Decimal(12, 2)
  admin_funded_discounts_cost Decimal  @default(0) @db.Decimal(12, 2)
  net_platform_revenue        Decimal  @db.Decimal(12, 2) // GENERATED ALWAYS AS
  new_users                   Int      @default(0)
  new_sellers                 Int      @default(0)
  generated_at                DateTime @default(now()) @db.Timestamptz

  @@map("platform_revenue")
}

// ==========================================
// SUPPORT TICKETS
// ==========================================

model SupportTicket {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reference_id      String   @unique @db.VarChar(50)
  sender_id         String   @db.Uuid
  issue_category    String   @db.VarChar(50)
  priority          String?  @default("normal") @db.VarChar(20)
  status            String?  @default("pending") @db.VarChar(20)
  assigned_admin_id String?  @db.Uuid
  order_id          String?  @db.Uuid
  product_id        String?  @db.Uuid
  created_at        DateTime @default(now()) @db.Timestamptz
  updated_at        DateTime @default(now()) @db.Timestamptz

  sender            User             @relation("TicketSender", fields: [sender_id], references: [id], onDelete: Cascade)
  assigned_admin    User?            @relation("TicketAssignee", fields: [assigned_admin_id], references: [id], onDelete: SetNull)
  order             Order?           @relation(fields: [order_id], references: [id], onDelete: SetNull)
  product           Product?         @relation(fields: [product_id], references: [id], onDelete: SetNull)
  messages          TicketMessage[]
  admin_meta        TicketAdminMeta?

  @@map("support_tickets")
}

model TicketMessage {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ticket_id        String    @db.Uuid
  sender_id        String?   @db.Uuid
  message_body     String
  read_at          DateTime? @db.Timestamptz
  created_at       DateTime  @default(now()) @db.Timestamptz

  ticket           SupportTicket @relation(fields: [ticket_id], references: [id], onDelete: Cascade)
  sender           User?         @relation(fields: [sender_id], references: [id], onDelete: SetNull)

  @@map("ticket_messages")
}

model TicketAdminMeta {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ticket_id     String    @unique @db.Uuid
  private_notes String?
  resolved_by   String?   @db.Uuid
  resolved_at   DateTime? @db.Timestamptz

  ticket        SupportTicket @relation(fields: [ticket_id], references: [id], onDelete: Cascade)
  resolver      User?         @relation("ResolvedBy", fields: [resolved_by], references: [id], onDelete: SetNull)

  @@map("ticket_admin_meta")
}

// ==========================================
// BANNERS & PROMOTIONS
// ==========================================

model Banner {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_by  String   @db.Uuid
  title       String?  @db.VarChar(200)
  subtitle    String?  @db.VarChar(300)
  img_url     String
  redirect_url String?
  description String?
  starts_at   DateTime @db.Timestamptz
  ends_at     DateTime @db.Timestamptz
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now()) @db.Timestamptz

  user        User            @relation(fields: [created_by], references: [id], onDelete: Restrict)
  payments    BannerPayment[]

  @@map("banners")
}

model BannerPayment {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  banner_id String   @db.Uuid
  seller_id String?  @db.Uuid
  amount    Decimal  @db.Decimal(12, 2)
  paid      Boolean  @default(false)
  created_at DateTime @default(now()) @db.Timestamptz

  banner    Banner  @relation(fields: [banner_id], references: [id], onDelete: Restrict)
  seller    Seller? @relation(fields: [seller_id], references: [id], onDelete: SetNull)

  @@map("banner_payments")
}
